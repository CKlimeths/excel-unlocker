{
    "include": [
        "src/**/*" // 只编译 src 目录下的文件
    ],
    "compilerOptions": {
        // File Layout
        "rootDir": "./src",
        "outDir": "./dist",

        // Environment Settings
        "module": "nodenext",
        "target": "esnext",
        "types": ["node"],
        // For nodejs:
        "lib": ["esnext"],

        // Other Outputs
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,

        // Stricter Typechecking Options
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,

        // Recommended Options
        "strict": true,
        "allowJs": false
    }
}
