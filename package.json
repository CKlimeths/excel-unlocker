{
    "name": "excel-unlocker",
    "author": "CKlimeths",
    "description": "xlsx工作表保护移除软件 - 命令行工具，支持工作表保护移除和添加",
    "type": "module",
    "module": "./src/main.ts",
    "private": true,
    "version": "0.1.0",
    "scripts": {
        "start": "bun run src/main.ts",
        "build": "bun build src/main.ts --compile --target=bun-windows-x64 --minify --outfile dist/excel-unlocker.exe"
    },
    "dependencies": {
        "commander": "^12.1.0",
        "exceljs": "^4.4.0"
    },
    "devDependencies": {
        "@types/bun": "latest"
    },
    "peerDependencies": {
        "typescript": "^5.9.3"
    },
    "engines": {
        "bun": ">=1.0.0"
    }
}